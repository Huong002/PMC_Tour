@startuml
skinparam participantBackgroundColor Yellow
skinparam lifelineStrategy solid

actor "Người dùng / Quản trị viên" as User #Yellow
boundary "TourDetailPage" as UI #Yellow
boundary "AxiosClient" as API #Yellow
control "JwtMiddleware" as MW #Yellow
control "BookingsController" as Ctrl #Yellow
control "BookingService" as Svc #Yellow
entity "Booking" as BEnt #Yellow
entity "Tour" as TEnt #Yellow
entity "Customer" as CEnt #Yellow
entity "BookingDetail" as BDEnt #Yellow
database "PostgreSQL" as DB #Yellow

User -> UI : 1: Điền form đặt tour\n(chọn ngày, số người lớn/trẻ em,\nnhập ghi chú, mã giảm giá)
activate UI
UI -> UI : 1.1: Validate phía client:\n- TourId hợp lệ\n- StartDate, EndDate không rỗng\n- NumAdults > 0\n- NumChildren >= 0
UI -> API : 1.2: POST /api/Bookings\nHeader: Authorization: Bearer {token}\nBody: CreateBookingRequest
activate API

API -> API : 1.3: Axios interceptor: gắn Bearer token
API -> MW : 1.4: Request qua JwtMiddleware
activate MW
MW -> MW : 1.5: ValidateToken
alt 1.6: [Token không hợp lệ]
MW --> API : 1.6.1: 401
API --> UI : 1.6.2: Redirect login
else 1.7: [Token hợp lệ]
MW -> MW : 1.7.1: Parse userId từ claim
MW --> Ctrl : 1.7.2: Chuyển tiếp
deactivate MW

activate Ctrl
Ctrl -> Ctrl : 1.8: Parse userId từ\nClaimTypes.NameIdentifier
Ctrl -> Ctrl : 1.9: Validate request\n(FluentValidation CreateBookingRequestValidator)
alt 1.10: [Validation thất bại]
Ctrl --> API : 1.10.1: 400 Bad Request
API --> UI : 1.10.2: Lỗi validation
else 1.11: [Validation thành công]
Ctrl -> Svc : 1.11.1: CreateAsync(request, userId)
activate Svc

Svc -> DB : 1.11.2: Tours.GetByIdAsync(request.TourId)
activate DB
DB --> Svc : 1.11.2.1: Tour hoặc null
deactivate DB

alt 1.11.3: [Tour không tồn tại]
Svc --> Ctrl : 1.11.3.1: ApiResponse.Fail("Tour not found", 404)
else 1.11.4: [Tour tồn tại]
Svc -> DB : 1.11.4.1: Customers.GetByIdAsync(request.CustomerId)
activate DB
DB --> Svc : 1.11.4.1.1: Customer hoặc null
deactivate DB

alt 1.11.4.2: [Customer không tồn tại]
Svc --> Ctrl : 1.11.4.2.1: ApiResponse.Fail(\n"Customer not found", 404)
else 1.11.4.3: [Customer tồn tại]

Svc -> Svc : 1.11.4.3.1: _mapper.Map<Booking>(request)
Svc -> Svc : 1.11.4.3.2: booking.BookingCode = GenerateBookingCode()\n"BK{yyyyMMdd}{random 5 số}"
Svc -> Svc : 1.11.4.3.3: Tính TotalPrice:\n(NumAdults * tour.PriceAdult)\n+ (NumChildren * tour.PriceChild)
Svc -> Svc : 1.11.4.3.4: booking.FinalPrice = TotalPrice\nbooking.Status = Pending\nbooking.CreatedBy = userId

alt 1.11.4.3.5: [request.BookingDetail != null]
Svc -> Svc : 1.11.4.3.5.1: booking.BookingDetails.Add(\nnew BookingDetail {\nFullName, PassportNumber, Note\n})
else 1.11.4.3.6: [Không có BookingDetail]
end

Svc -> DB : 1.11.4.3.7: Bookings.AddAsync(booking)
activate DB
DB --> Svc : OK
deactivate DB
Svc -> DB : 1.11.4.3.8: SaveChangesAsync()
activate DB
DB --> Svc : 1.11.4.3.8.1: OK (Booking đã tạo)
deactivate DB

Svc -> DB : 1.11.4.3.9: GetByIdAsync(booking.Id)\n(có Customer, Tour, BookingDetails)
activate DB
DB --> Svc : 1.11.4.3.9.1: Booking đầy đủ
deactivate DB
Svc --> Ctrl : 1.11.4.3.10: ApiResponse.Ok(data,\n"Booking created successfully")
end
end
end

deactivate Svc
Ctrl --> API : 1.12: StatusCode(200)
deactivate Ctrl
API --> UI : 1.13: Response JSON booking mới
deactivate API

UI -> UI : 1.14: Thông báo thành công\n(invalidate query cache)
UI --> User : 1.15: "Booking created successfully"
deactivate UI

end

@enduml
