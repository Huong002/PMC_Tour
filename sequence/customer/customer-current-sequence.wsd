@startuml
skinparam participantBackgroundColor Yellow
skinparam lifelineStrategy solid

actor "Người dùng" as User #Yellow
boundary "TourDetailPage" as UI #Yellow
boundary "AxiosClient" as API #Yellow
control "JwtMiddleware" as MW #Yellow
control "CustomersController" as Ctrl #Yellow
control "CustomerService" as Svc #Yellow
entity "User" as UEnt #Yellow
entity "Customer" as CEnt #Yellow
database "PostgreSQL" as DB #Yellow

User -> UI : 1: Bắt đầu đặt tour\n(cần thông tin khách hàng)
activate UI
UI -> UI : 1.1: Kiểm tra accessToken
UI -> API : 1.2: GET /api/Customers/current\nHeader: Authorization: Bearer {token}
activate API

API -> API : 1.3: Axios interceptor: gắn Bearer token
API -> MW : 1.4: Request qua JwtMiddleware
activate MW
MW -> MW : 1.5: ValidateToken
alt 1.6: [Token không hợp lệ]
MW --> API : 1.6.1: 401
API --> UI : 1.6.2: Redirect login
else 1.7: [Token hợp lệ]
MW -> MW : 1.7.1: Parse userId từ\nClaimTypes.NameIdentifier
MW --> Ctrl : 1.7.2: Chuyển tiếp
deactivate MW

activate Ctrl
Ctrl -> Ctrl : 1.8: Parse userId từ claim
Ctrl -> Svc : 1.9: GetCurrentCustomerAsync(userId)
activate Svc

Svc -> DB : 1.10: Users.GetByIdAsync(userId)
activate DB
DB --> Svc : 1.10.1: User hoặc null
deactivate DB

alt 1.11: [User không tồn tại]
Svc --> Ctrl : 1.11.1: ApiResponse.Fail(\n"User not found", 404)
Ctrl --> API : 1.11.2: 404
API --> UI : 1.11.3: Lỗi
else 1.12: [User tồn tại]

Svc -> DB : 1.12.1: Customers.GetQueryable()\n.FirstOrDefaultAsync(c => c.UserId == userId\n&& !c.IsDeleted)
activate DB
DB --> Svc : 1.12.1.1: Customer hoặc null
deactivate DB

alt 1.12.2: [Customer theo UserId không tồn tại]
Svc -> DB : 1.12.2.1: Customers.GetQueryable()\n.FirstOrDefaultAsync(c => c.Email == user.Email\n&& !c.IsDeleted)
activate DB
DB --> Svc : 1.12.2.1.1: Customer hoặc null
deactivate DB

alt 1.12.2.2: [Vẫn không tìm thấy]
note right of Svc : Tự động tạo Customer mới\ntừ thông tin User
Svc -> Svc : 1.12.2.2.1: Tạo Customer mới:\nUserId = userId\nFullName = user.FullName\nEmail = user.Email\nPhone = user.Phone\nIsActive = true
Svc -> DB : 1.12.2.2.2: Customers.AddAsync(customer)
activate DB
DB --> Svc : OK
deactivate DB
Svc -> DB : 1.12.2.2.3: SaveChangesAsync()
activate DB
DB --> Svc : OK
deactivate DB
else 1.12.2.3: [Tìm thấy Customer qua Email]
alt 1.12.2.3.1: [customer.UserId == null]
note right of Svc : Liên kết Customer với User
Svc -> Svc : customer.UserId = userId
Svc -> DB : Customers.UpdateAsync(customer)\nSaveChangesAsync()
activate DB
DB --> Svc : OK
deactivate DB
end
end
else 1.12.3: [Customer đã tồn tại theo UserId]
end

Svc -> Svc : 1.12.4: _mapper.Map<CustomerResponse>(customer)
Svc --> Ctrl : 1.12.5: ApiResponse.Ok(data)
end

deactivate Svc
Ctrl --> API : 1.13: 200 OK
deactivate Ctrl
API --> UI : 1.14: Response JSON\n{ id, fullName, email, phone }
deactivate API

UI -> UI : 1.15: Tự động điền form đặt tour\nvới thông tin khách hàng
UI --> User : 1.16: Form đã có sẵn thông tin\n(sẵn sàng đặt tour)
deactivate UI

@enduml
