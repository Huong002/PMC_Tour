@startuml
skinparam participantBackgroundColor Yellow
skinparam lifelineStrategy solid

actor "Người dùng" as User #Yellow
boundary "RegisterPage" as UI #Yellow
boundary "AxiosClient" as API #Yellow
control "AuthController" as Ctrl #Yellow
control "AuthService" as Svc #Yellow
entity "User" as UserEnt #Yellow
entity "Role" as RoleEnt #Yellow
entity "UserRole" as UREnt #Yellow
database "PostgreSQL" as DB #Yellow

User -> UI : 1: Nhập FullName, Email, Phone,\nPassword, ConfirmPassword
activate UI
UI -> UI : 1.1: Validate phía client:\n- password === confirmPassword\n- termsAccepted == true
UI -> API : 1.2: POST /api/Auth/register\n{ username, email, password, fullName, phone }
activate API
API -> Ctrl : 1.3: Chuyển tiếp request
activate Ctrl
Ctrl -> Ctrl : 1.4: Chuyển đổi JSON body -> RegisterRequest
Ctrl -> Svc : 1.5: RegisterAsync(request)
activate Svc

Svc -> DB : 1.6: Users.IgnoreQueryFilters()\n.AnyAsync(u => u.Username == request.Username)
activate DB
DB --> Svc : 1.6.1: true/false
deactivate DB

alt 1.7: [Username đã tồn tại]
Svc --> Ctrl : 1.7.1: ApiResponse.Fail("Username already exists")
else 1.8: [Username chưa tồn tại]
Svc -> DB : 1.8.1: Users.IgnoreQueryFilters()\n.AnyAsync(u => u.Email == request.Email)
activate DB
DB --> Svc : 1.8.1.1: true/false
deactivate DB

alt 1.8.2: [Email đã tồn tại]
Svc --> Ctrl : 1.8.2.1: ApiResponse.Fail("Email already exists")
else 1.8.3: [Email chưa tồn tại]
Svc -> DB : 1.8.3.1: Roles.FirstOrDefaultAsync(r => r.Name == "Customer")
activate DB
DB --> Svc : 1.8.3.1.1: Role (Customer) hoặc null
deactivate DB

alt 1.8.3.2: [Role "Customer" không tồn tại]
Svc --> Ctrl : 1.8.3.2.1: ApiResponse.Fail("Default role not found", 500)
else 1.8.3.3: [Role tồn tại]
Svc -> Svc : 1.8.3.3.1: HashPassword(password) \\n(BCrypt.HashPassword)
Svc -> Svc : 1.8.3.3.2: Tạo User entity\n(Username, Email, PasswordHash,\nFullName, Phone, IsActive=true)
Svc -> Svc : 1.8.3.3.3: user.UserRoles.Add(\nnew UserRole { RoleId = customerRole.Id })
Svc -> DB : 1.8.3.3.4: Users.AddAsync(user)
activate DB
DB --> Svc : 1.8.3.3.4.1: OK
deactivate DB
Svc -> DB : 1.8.3.3.5: SaveChangesAsync()
activate DB
DB --> Svc : 1.8.3.3.5.1: OK (User đã được tạo)
deactivate DB

Svc -> Svc : 1.8.3.3.6: GenerateJwtToken(user)\n(claims + 24h expiry)
Svc -> Svc : 1.8.3.3.7: GenerateRefreshToken()\n(32 bytes random -> Base64)
Svc -> DB : 1.8.3.3.8: user.RefreshToken = newToken\nuser.RefreshTokenExpiry = UtcNow+7d\nSaveChangesAsync()
activate DB
DB --> Svc : 1.8.3.3.8.1: OK
deactivate DB

Svc -> Svc : 1.8.3.3.9: Tạo LoginResponse
Svc --> Ctrl : 1.8.3.3.10: ApiResponse.Ok(LoginResponse,\n"Registration successful")
end
end
end

deactivate Svc
Ctrl --> API : 1.9: StatusCode(200, ApiResponse<LoginResponse>)
deactivate Ctrl
API --> UI : 1.10: Response JSON (token, refreshToken,\nuserId, username, fullName, roles)
deactivate API

UI -> UI : 1.11: useAuth.onSuccess:\n- localStorage.setItem tokens\n- setQueryData authUser
UI -> UI : 1.12: router.push("/dashboard")
UI --> User : 1.13: Chuyển hướng đến Dashboard
deactivate UI

@enduml
