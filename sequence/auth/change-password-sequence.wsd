@startuml
skinparam participantBackgroundColor Yellow
skinparam lifelineStrategy solid

actor "Người dùng" as User #Yellow
boundary "DashboardPage" as UI #Yellow
boundary "AxiosClient" as API #Yellow
control "JwtMiddleware" as MW #Yellow
control "AuthController" as Ctrl #Yellow
control "AuthService" as Svc #Yellow
entity "User" as UserEnt #Yellow
database "PostgreSQL" as DB #Yellow

User -> UI : 1: Mở form đổi mật khẩu\nnhập oldPassword + newPassword
activate UI
UI -> UI : 1.1: Validate phía client:\n- oldPassword không trống\n- newPassword >= 6 ký tự
UI -> API : 1.2: POST /api/Auth/change-password\nHeader: Authorization: Bearer {token}\nBody: { oldPassword, newPassword }
activate API

API -> API : 1.3: Axios interceptor:\nđính kèm Bearer token từ localStorage
API -> MW : 1.4: Request qua JwtMiddleware
activate MW
MW -> MW : 1.5: Trích xuất token\nValidateToken (Issuer, Audience, Key)
alt 1.6: [Token không hợp lệ]
MW --> API : 1.6.1: Request không có User context
API --> Ctrl : 1.6.2: Chuyển tiếp
Ctrl -> Ctrl : 1.6.3: [Authorize] phát hiện\nkhông có user -> 401
Ctrl --> API : 1.6.4: 401 Unauthorized
API --> UI : 1.6.5: Response 401
UI -> UI : 1.6.6: Axios interceptor:\nxoá token + redirect /login
UI --> User : 1.6.7: Chuyển hướng đăng nhập
else 1.7: [Token hợp lệ]
MW -> MW : 1.7.1: Parse userId từ\nClaimTypes.NameIdentifier
MW -> Svc : 1.7.2: GetEntityByIdAsync(userId)
activate Svc
Svc -> DB : 1.7.3: Users.GetQueryable()\n.FirstOrDefaultAsync(u => u.Id == id)
activate DB
DB --> Svc : 1.7.3.1: User entity
deactivate DB
Svc --> MW : 1.7.4: User
deactivate Svc
MW -> MW : 1.7.5: HttpContext.Items["User"] = user
MW --> Ctrl : 1.7.6: Chuyển tiếp request
deactivate MW

activate Ctrl
Ctrl -> Ctrl : 1.8: User.FindFirst(ClaimTypes.NameIdentifier)\n-> userId (int)
Ctrl -> Svc : 1.9: ChangePasswordAsync(userId, request)
activate Svc

Svc -> DB : 1.10: Users.GetByIdAsync(userId)
activate DB
DB --> Svc : 1.10.1: User hoặc null
deactivate DB

alt 1.11: [user == null]
Svc --> Ctrl : 1.11.1: ApiResponse<bool>.Fail(\n"User not found", 404)
Ctrl --> API : 1.11.2: StatusCode(404)
API --> UI : 1.11.3: Response lỗi
UI --> User : 1.11.4: Hiển thị "User not found"
else 1.12: [user != null]
Svc -> Svc : 1.12.1: VerifyPassword(oldPassword, user.PasswordHash)\n(BCrypt.Verify)
alt 1.12.2: [Mật khẩu cũ sai]
Svc --> Ctrl : 1.12.2.1: ApiResponse<bool>.Fail(\n"Old password is incorrect")
Ctrl --> API : 1.12.2.2: StatusCode(400)
API --> UI : 1.12.2.3: Response lỗi
UI --> User : 1.12.2.4: Hiển thị "Old password is incorrect"
else 1.12.3: [Mật khẩu cũ đúng]
Svc -> Svc : 1.12.3.1: HashPassword(newPassword)\n(BCrypt.HashPassword)
Svc -> DB : 1.12.3.2: user.PasswordHash = newHash\nSaveChangesAsync()
activate DB
DB --> Svc : 1.12.3.2.1: OK
deactivate DB
Svc --> Ctrl : 1.12.3.3: ApiResponse<bool>.Ok(true,\n"Password changed successfully")
end
end

deactivate Svc
Ctrl --> API : 1.13: StatusCode(200)
deactivate Ctrl
API --> UI : 1.14: Response JSON\n{ success: true, data: true,\nmessage: "Password changed successfully" }
deactivate API

UI --> User : 1.15: Hiển thị thông báo\n"Mật khẩu đã được thay đổi thành công"
deactivate UI

@enduml
